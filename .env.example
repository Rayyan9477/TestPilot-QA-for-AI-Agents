# TestPilot — environment template. NEVER commit real values (CI runs gitleaks).
#
# Runtime LLM for the fixer = UiPath AI Trust Layer LLM Gateway (keyless from serverless).
# No Anthropic key is needed on the demo path. The values below are LOCAL-DEV FALLBACK ONLY.

UIPATH_URL=https://cloud.uipath.com/<org>/<tenant>
UIPATH_CLIENT_ID=replace-me
UIPATH_CLIENT_SECRET=replace-me          # consumed via env ref / Credential Asset — never on argv

# GitHub push from inside the fixer (gh CLI) — fine-grained, single-repo, contents+PR only.
GITHUB_TOKEN=replace-me

# Dev-only fallbacks (never used on camera):
AWS_REGION=us-east-1
# ANTHROPIC_API_KEY=replace-me           # only for the direct-Anthropic dev fallback
